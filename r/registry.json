{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "vstack",
  "homepage": "https://github.com/Vvs2705/vstack-registry",
  "items": [
    {
      "name": "design-conventions",
      "type": "registry:item",
      "title": "V-STACK Design Conventions",
      "description": "Fonte da verdade do design system da V-STACK Solutions (DESIGN.md): tokens semanticos (accent laranja, superficies, texto, raio, sombra), tipografia Syne/Geist/JetBrains Mono e regras anti-generico. Instala o DESIGN.md na raiz do projeto consumidor.",
      "files": [
        {
          "path": "DESIGN.md",
          "type": "registry:file",
          "target": "~/DESIGN.md"
        }
      ]
    },
    {
      "name": "theme-base",
      "type": "registry:theme",
      "title": "V-STACK Theme (tokens + utilities)",
      "description": "Fundacao visual instalavel da V-STACK: injeta os design tokens (custom properties --bg*, --accent*, --text-1..3, --border*, --radius-*, sombras, --accent-muted e tokens de estado success/warning/danger/info) em light e dark, mais as utilities que os componentes registry:ui assumem (.eyebrow, .btn-primary/.btn-secondary/.btn-outline, .card-vstack, .gradient-text, font-display, font-mono) e o keyframe tech-scroll. Instale ESTE item antes (ou junto) dos componentes registry:ui.",
      "cssVars": {
        "light": {
          "bg": "#f6f7fb",
          "bg-deep": "#eef1f7",
          "bg-card": "#ffffff",
          "bg-overlay": "rgba(246, 247, 251, 0.92)",
          "accent": "#e05e18",
          "accent-light": "#f07028",
          "accent-soft": "#ffb270",
          "accent-muted": "rgba(224, 94, 24, 0.1)",
          "accent-border": "rgba(224, 94, 24, 0.28)",
          "success": "#15803d",
          "warning": "#b45309",
          "danger": "#b91c1c",
          "info": "#1d4ed8",
          "text-1": "#101522",
          "text-2": "#526071",
          "text-3": "#8b96a8",
          "border": "rgba(16, 21, 34, 0.1)",
          "border-strong": "rgba(16, 21, 34, 0.16)",
          "border-hover": "rgba(224, 94, 24, 0.42)",
          "shadow-sm": "0 12px 32px rgba(16, 21, 34, 0.08)",
          "shadow": "0 28px 80px rgba(16, 21, 34, 0.14)",
          "shadow-glow": "0 22px 70px rgba(224, 94, 24, 0.18)",
          "radius-sm": "8px",
          "radius-md": "12px",
          "radius-card": "18px",
          "radius-panel": "28px",
          "radius-btn": "12px",
          "nav-blur": "rgba(246, 247, 251, 0.86)"
        },
        "dark": {
          "bg": "#0d1422",
          "bg-deep": "#080e1a",
          "bg-card": "#121b2c",
          "bg-overlay": "rgba(13, 20, 34, 0.88)",
          "accent": "#f07028",
          "accent-light": "#ff8c48",
          "accent-soft": "#ffb270",
          "accent-muted": "rgba(240, 112, 40, 0.14)",
          "accent-border": "rgba(240, 112, 40, 0.32)",
          "success": "#4ade80",
          "warning": "#fbbf24",
          "danger": "#f87171",
          "info": "#60a5fa",
          "text-1": "#eef2ff",
          "text-2": "#a7b1c4",
          "text-3": "#8b97ab",
          "border": "rgba(238, 242, 255, 0.1)",
          "border-strong": "rgba(238, 242, 255, 0.16)",
          "border-hover": "rgba(240, 112, 40, 0.45)",
          "shadow-sm": "0 12px 32px rgba(0, 0, 0, 0.3)",
          "shadow": "0 30px 90px rgba(0, 0, 0, 0.48)",
          "shadow-glow": "0 26px 90px rgba(240, 112, 40, 0.18)",
          "nav-blur": "rgba(13, 20, 34, 0.84)"
        }
      },
      "css": {
        "@layer components": {
          ".btn-primary, .btn-secondary, .btn-outline": {
            "display": "inline-flex",
            "align-items": "center",
            "justify-content": "center",
            "gap": "0.5rem",
            "border-radius": "var(--radius-btn)",
            "font-weight": "700",
            "line-height": "1",
            "transition": "transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease, color 180ms ease"
          },
          ".btn-primary": {
            "border": "1px solid var(--accent-border)",
            "background": "linear-gradient(135deg, var(--accent), var(--accent-light))",
            "color": "white",
            "box-shadow": "var(--shadow-glow)",
            "position": "relative",
            "overflow": "hidden",
            "&::after": {
              "content": "''",
              "position": "absolute",
              "inset": "0",
              "background": "linear-gradient(135deg, rgba(255,255,255,0.15), transparent)",
              "opacity": "0",
              "transition": "opacity 200ms ease"
            },
            "&:hover": {
              "transform": "translateY(-2px)",
              "box-shadow": "0 20px 60px rgba(224, 94, 24, 0.35)"
            },
            "&:hover::after": {
              "opacity": "1"
            },
            "&:active": {
              "transform": "translateY(0)",
              "box-shadow": "var(--shadow-glow)"
            }
          },
          ".btn-secondary": {
            "border": "1px solid var(--border)",
            "background": "var(--bg-card)",
            "color": "var(--text-1)",
            "&:hover": {
              "border-color": "var(--border-hover)",
              "background": "var(--accent-muted)",
              "color": "var(--accent)",
              "transform": "translateY(-1px)"
            },
            "&:active": {
              "transform": "translateY(0)"
            }
          },
          ".btn-outline": {
            "border": "1px solid var(--accent-border)",
            "background": "transparent",
            "color": "var(--accent)",
            "&:hover": {
              "border-color": "var(--accent)",
              "background": "var(--accent-muted)",
              "transform": "translateY(-1px)"
            },
            "&:active": {
              "transform": "translateY(0)"
            }
          },
          ".card-vstack": {
            "border": "1px solid var(--border)",
            "border-radius": "var(--radius-card)",
            "background": "var(--bg-card)",
            "box-shadow": "var(--shadow-sm)"
          },
          ".accent-glow": {
            "box-shadow": "var(--shadow-glow)"
          },
          ".eyebrow": {
            "font-size": "0.7rem",
            "font-weight": "800",
            "letter-spacing": "0.18em",
            "text-transform": "uppercase",
            "color": "var(--accent)"
          }
        },
        "@utility font-display": {
          "font-family": "var(--font-syne, \"Syne\"), sans-serif"
        },
        "@utility font-mono": {
          "font-family": "var(--font-jetbrains-mono, \"JetBrains Mono\"), monospace"
        },
        "@utility gradient-text": {
          "background": "linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 55%, var(--accent-soft) 100%)",
          "-webkit-background-clip": "text",
          "background-clip": "text",
          "-webkit-text-fill-color": "transparent"
        },
        "@utility animate-tech-scroll": {
          "animation": "techScroll 36s linear infinite"
        },
        "@keyframes techScroll": {
          "0%": {
            "transform": "translateX(0)"
          },
          "100%": {
            "transform": "translateX(-50%)"
          }
        }
      }
    },
    {
      "name": "currency-input",
      "type": "registry:ui",
      "title": "Currency Input (BRL)",
      "description": "Input de moeda brasileira com mascara automatica (acumulador de centavos): digitar '421850' vira '4.218,50'. Value canonico com ponto decimal, pronto para parseFloat/API e react-hook-form. Sem estilo proprio — herda className do consumidor.",
      "files": [
        {
          "path": "registry/currency-input/CurrencyInput.tsx",
          "type": "registry:ui",
          "target": "components/ui/CurrencyInput.tsx"
        },
        {
          "path": "registry/currency-input/currency.ts",
          "type": "registry:lib",
          "target": "lib/currency.ts"
        }
      ]
    },
    {
      "name": "empty-state",
      "type": "registry:ui",
      "title": "Empty State",
      "description": "Estado vazio padrao V-STACK: icone (Lottie opcional ou SVG), titulo em font-display, descricao e acao. Usa apenas tokens semanticos shadcn (text-primary/foreground/muted-foreground) — a identidade vem do mapeamento de tokens do consumidor. Requer tailwindcss-animate (animate-in).",
      "dependencies": [
        "lottie-react"
      ],
      "files": [
        {
          "path": "registry/empty-state/empty-state.tsx",
          "type": "registry:ui",
          "target": "components/ui/empty-state.tsx"
        }
      ]
    },
    {
      "name": "container",
      "type": "registry:ui",
      "title": "Container",
      "description": "Container centralizado com gutters responsivos e largura maxima por prop (md/lg/xl) no padrao V-STACK.",
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "registry/ui/container.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "section",
      "type": "registry:ui",
      "title": "Section",
      "description": "Secao de pagina com tom de fundo (default/muted/deep) e ritmo vertical (md/lg/xl) padronizados pelos tokens V-STACK.",
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "registry/ui/section.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "section-header",
      "type": "registry:ui",
      "title": "SectionHeader",
      "description": "Cabecalho de secao no padrao V-STACK: eyebrow + titulo + descricao, com alinhamento left/center.",
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "registry/ui/section-header.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "surface",
      "type": "registry:ui",
      "title": "Surface",
      "description": "Superficie elevada (card) com borda, raio e sombra por token, hover de elevacao opcional (interactive) e elemento polimorfico via as.",
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "registry/ui/surface.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "cta-section",
      "type": "registry:ui",
      "title": "CTASection",
      "description": "Secao final de call-to-action com entrada animada on-scroll, glow radial sutil e ate dois CTAs. Toda a copy vem por props. Requer Next.js (next/link).",
      "dependencies": [
        "framer-motion",
        "lucide-react"
      ],
      "registryDependencies": [
        "Vvs2705/vstack-registry/container",
        "Vvs2705/vstack-registry/section"
      ],
      "files": [
        {
          "path": "registry/ui/cta-section.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "animations",
      "type": "registry:ui",
      "title": "Animations",
      "description": "Primitivos de animacao on-scroll da V-STACK (framer-motion): FadeInUp, SlideIn, StaggerContainer/StaggerItem, PulseLabel, CountUp, AnimatedSection e variants compartilhados.",
      "dependencies": [
        "framer-motion"
      ],
      "files": [
        {
          "path": "registry/ui/animations.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "toast",
      "type": "registry:ui",
      "title": "Toast",
      "description": "Toast leve sem provider: funcao toast() via event bus global + ToastContainer com AnimatePresence, tipos success/error/info mapeados aos tokens de estado.",
      "dependencies": [
        "framer-motion",
        "lucide-react"
      ],
      "files": [
        {
          "path": "registry/ui/toast.tsx",
          "type": "registry:ui"
        }
      ]
    }
  ]
}
